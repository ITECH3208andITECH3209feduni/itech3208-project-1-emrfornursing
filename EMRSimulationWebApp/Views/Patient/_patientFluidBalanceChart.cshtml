@using EMRSimulation.Domain.Dtos;
@using EMRSimulationWebApp.Models;
@model PatientFluidBalanceChartViewModel

<div class="container-fluid mt-2">
    <h5 class="mb-3">Fluid Balance Record</h5>
    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <label class="form-label">Chart Date</label>
            <input type="text" class="form-control" value="@Model.FluidBalanceChartDto?.ChartDate.ToShortDateString()" disabled />
        </div>
        <div class="col-md-3">
            <label class="form-label">Chart Time</label>
            <input type="text" class="form-control" value="@Model.FluidBalanceChartDto?.ChartTime" disabled />
        </div>
        <div class="col-md-3">
            <label class="form-label">Previous Day Balance (ml)</label>
            <input type="text" class="form-control" value="@Model.FluidBalanceChartDto?.PreviousDayBalance" disabled />
        </div>
        <div class="col-md-3">
            <label class="form-label">Total Intake (ml)</label>
            <input type="text" class="form-control" value="@Model.FluidBalanceChartDto?.TotalIntake" disabled />
        </div>
        <div class="col-md-3">
            <label class="form-label">Total Output (ml)</label>
            <input type="text" class="form-control" value="@Model.FluidBalanceChartDto?.TotalOutput" disabled />
        </div>
        <div class="col-md-3">
            <label class="form-label">Balance (ml)</label>
            <input type="text" class="form-control" value="@Model.FluidBalanceChartDto?.Balance" disabled />
        </div>
        <div class="col-md-3">
            <label class="form-label">Total Balance (ml)</label>
            <input type="text" class="form-control" value="@Model.FluidBalanceChartDto?.TotalBalance" disabled />
        </div>
    </div>
    @if (Model.FluidBalanceChartDto?.Entries != null && Model.FluidBalanceChartDto.Entries.Count > 0)
    {
        <h6 class="mt-3">Entries</h6>
        <table class="table table-bordered table-sm">
            <thead class="table-light">
                <tr><th>Time</th><th>Type</th><th>Category</th><th>Amount (ml)</th></tr>
            </thead>
            <tbody>
                @foreach (var e in Model.FluidBalanceChartDto.Entries)
                {
                    <tr>
                        <td>@e.EntryTime</td>
                        <td>@e.EntryType</td>
                        <td>@e.Category</td>
                        <td>@e.AmountMl</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    @if (Model.FluidBalanceChartDto?.ClinicalNotes != null)
    {
        <div class="mt-3">
            <label class="form-label">Clinical Notes</label>
            <textarea class="form-control" rows="3" disabled>@Model.FluidBalanceChartDto.ClinicalNotes</textarea>
        </div>
    }
</div>