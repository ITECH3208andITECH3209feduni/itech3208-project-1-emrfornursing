@using EMRSimulation.Domain.Dtos;
@using EMRSimulationWebApp.Models;
@model PatientFluidBalanceChartViewModel
@{
    var times = new[] {
        "0000","0100","0200","0300","0400","0500","0600","0700","0800","0900",
        "1000","1100","1200","1300","1400","1500","1600","1700","1800","1900",
        "2000","2100","2200","2300","2400"
    };
}

<div class="container-fluid mt-3 fluid-page">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">Fluid Balance Chart</h2>
            <p class="text-muted mb-0">Digital chart for recording fluid intake and output over 24 hours.</p>
        </div>
        <div class="no-print">
            <button id="btnSaveChart" class="btn btn-primary px-4">Save Chart</button>
            <span id="saveMsg" class="ms-3 fw-semibold"></span>
        </div>
    </div>

    
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-bold">Chart Details</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Chart Date <span class="text-muted small">(completion)</span></label>
                    <input type="date" id="chartDate" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Chart Time <span class="text-muted small">(completion)</span></label>
                    <input type="time" id="chartTime" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Prev Day Balance - Auto (mL)</label>
                    <input id="prevAuto" type="number" class="form-control bg-light" value="@Model.PreviousDayBalanceAuto" readonly
                           title="Auto-calculated from most recent chart" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Prev Day Balance - Manual (mL)</label>
                    <input id="prevManual" type="number" class="form-control" min="0" placeholder="Manual Override" />
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3 no-print">
        <div class="card-header fw-bold">Fluid Balance Entry</div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Date</label>
                    <input type="date" id="entryDate" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Time</label>
                    <select id="time" class="form-control">
                        <option value="">Select Time</option>
                        @foreach (var t in times)
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Type</label>
                    <select id="type" class="form-control">
                        <option value="">Select Type</option>
                        <option value="Intake">Input</option>
                        <option value="Output">Output</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Category</label>
                    <select id="cat" class="form-control">
                        <option value="">Select Category</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Amount (mL)</label>
                    <input id="ml" type="number" class="form-control" min="0" placeholder="mL" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">Initials</label>
                    <input id="initials" type="text" class="form-control" maxlength="10" placeholder="RN" />
                </div>
                <div class="col-md-1">
                    <button class="btn btn-dark w-100" onclick="addEntry()">Add Entry</button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card shadow-sm text-center"><div class="card-body"><div class="fw-bold">Total Intake</div><div id="inT" class="summary-value">0</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm text-center"><div class="card-body"><div class="fw-bold">Total Output</div><div id="outT" class="summary-value">0</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm text-center"><div class="card-body"><div class="fw-bold">Balance</div><div id="bal" class="summary-value">0</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm text-center"><div class="card-body"><div class="fw-bold">Total Balance</div><div id="tbal" class="summary-value">0</div></div></div></div>
    </div>

    <div id="printSection" class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-bold">24-Hour Fluid Record Table</span>
            <button type="button" class="btn btn-success btn-sm no-print" onclick="printTableSection()">Print Table</button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered text-center align-middle" id="fluidTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width:110px;">Time</th>
                            <th>Fluid Input</th>
                            <th>Output Measurement</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in times)
                        {
                            <tr data-time="@t">
                                <td class="fw-bold">@t</td>
                                <td class="in"></td>
                                <td class="out"></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-4 pt-3 border-top">
                <h6 class="fw-bold mb-3">Clinical Notes</h6>
                <textarea id="clinicalNotes" class="form-control" rows="4" placeholder="Enter clinical notes..."></textarea>
            </div>
            <div class="mt-4 pt-3 border-top signature-block">
                <h6 class="fw-bold mb-3">Signature</h6>
                <canvas id="signaturePad"></canvas>
                <div class="mt-2 no-print">
                    <button type="button" class="btn btn-secondary btn-sm" onclick="clearSignature()">Clear Signature</button>
                </div>
            </div>
        </div>
    </div>
    <div class="d-flex justify-content-end align-items-center mt-3 mb-2 no-print">
        <span id="saveMsg2" class="me-3 fw-semibold"></span>
        <button class="btn btn-primary px-4" onclick="document.getElementById('btnSaveChart').click()">Save Chart</button>
    </div>
</div>

<style>
    .fluid-page { background: #f5f5f5; padding-bottom: 30px; }
    .summary-value { font-size: 28px; font-weight: 700; color: #1f3b64; margin-top: 8px; }
    #fluidTable td { min-height: 50px; height: 50px; }
    .entry-chip { display: inline-flex; align-items: center; margin: 4px 4px 0 0; padding: 5px 10px; border-radius: 14px; font-size: 13px; font-weight: 600; gap: 6px; }
    .entry-chip.input  { background: #e8f1ff; border: 1px solid #bcd3ff; color: #153b75; }
    .entry-chip.output { background: #fff1e8; border: 1px solid #ffd1b3; color: #8a3d08; }
    .entry-chip .del-btn { cursor: pointer; font-size: 15px; line-height: 1; opacity: .65; }
    .entry-chip .del-btn:hover { opacity: 1; }
    .chip-ini { font-size: 11px; opacity: .75; font-style: normal; }
    #signaturePad { width: 100%; max-width: 100%; height: 220px; border: 1px solid #cfcfcf; border-radius: 8px; background: #fff; touch-action: none; cursor: crosshair; display: block; }
    @@media print {
        body * { visibility: hidden !important; }
        #printSection, #printSection * { visibility: visible !important; }
        #printSection { position: absolute; left: 0; top: 0; width: 100%; background: white; }
        .no-print { display: none !important; }
    }
</style>

<script>
    var entries = {};


    document.getElementById("type").addEventListener("change", function () {
        var cat = document.getElementById("cat");
        cat.innerHTML = "<option value=\"\">Select Category</option>";
        var list = this.value === "Intake"
            ? ["Oral Intake","IV Fluids","Enteric Intake","Other Input"]
            : ["Urine Output","Drainage","Vomit","Other Output"];
        list.forEach(function(x) { cat.innerHTML += "<option value=\"" + x + "\">" + x + "</option>"; });
    });

    document.getElementById("prevAuto").addEventListener("input", calc);
    document.getElementById("prevManual").addEventListener("input", calc);

    // When chart date changes, fetch the latest TotalBalance for the new date
    // (most recent chart BEFORE the selected date) and update prevAuto
    document.getElementById("chartDate").addEventListener("change", function() {
        var labId     = document.getElementById("txtLabId")     ? document.getElementById("txtLabId").value     : "";
        var patientId = document.getElementById("txtPatientId") ? document.getElementById("txtPatientId").value : "";
        if (!labId || !patientId) return;
        // Sync entryDate to chartDate if not manually set
        var entryEl = document.getElementById("entryDate");
        if (entryEl && !entryEl.dataset.manuallyChanged) {
            entryEl.value = this.value;
        }
        // Use entryDate for prevAuto lookup
        var lookupDate = document.getElementById("entryDate").value || this.value;
        $.ajax({
            url: "/patient/getlatestfluidbalancetotalbalance",
            method: "GET",
            data: { labId: labId, patientId: patientId, beforeDate: lookupDate },
            success: function(val) {
                document.getElementById("prevAuto").value = parseInt(val, 10) || 0;
                calc();
            },
            error: function() {
                document.getElementById("prevAuto").value = 0;
                calc();
            }
        });
        // Keep entryDate in sync with chartDate by default
        if (!document.getElementById("entryDate").dataset.manuallyChanged) {
            document.getElementById("entryDate").value = this.value;
        }
    });

    // When entryDate changes, fetch prevAuto based on the entry date
    document.getElementById("entryDate").addEventListener("change", function() {
        this.dataset.manuallyChanged = "1";
        var labId     = document.getElementById("txtLabId")     ? document.getElementById("txtLabId").value     : "";
        var patientId = document.getElementById("txtPatientId") ? document.getElementById("txtPatientId").value : "";
        if (!labId || !patientId) return;
        $.ajax({
            url: "/patient/getlatestfluidbalancetotalbalance",
            method: "GET",
            data: { labId: labId, patientId: patientId, beforeDate: this.value },
            success: function(val) {
                document.getElementById("prevAuto").value = parseInt(val, 10) || 0;
                calc();
            },
            error: function() { calc(); }
        });
    });

    function addEntry() {
        var d    = document.getElementById("entryDate").value;
        var t    = document.getElementById("time").value;
        var type = document.getElementById("type").value;
        var cat  = document.getElementById("cat").value;
        var ml   = parseInt(document.getElementById("ml").value, 10);
        if (!d || !t || !type || !cat || !ml || ml <= 0) { alert("Please fill all entry fields including Date."); return; }
        if (!entries[t]) entries[t] = [];
        var ini = document.getElementById("initials").value.trim();
        entries[t].push({ date: d, type: type, cat: cat, ml: ml, initials: ini });
        render();
        document.getElementById("ml").value = "";
    }

    function render() {
        document.querySelectorAll("#fluidTable tbody tr").forEach(function(row) {
            var t    = row.dataset.time;
            var ins  = (entries[t] || []).filter(function(e) { return e.type === "Intake"; });
            var outs = (entries[t] || []).filter(function(e) { return e.type === "Output"; });
            row.querySelector(".in").innerHTML  = ins.map(function(e,i)  { return chip(t, i, e, "input");  }).join("");
            row.querySelector(".out").innerHTML = outs.map(function(e,i) { return chip(t, i + ins.length, e, "output"); }).join("");
        });
        calc();
    }

    function chip(time, idx, e, cls, initials) {
        var sp = document.createElement("span");
        sp.className = "entry-chip " + cls;
        sp.dataset.time = time;
        sp.dataset.idx  = idx;
        var iniLabel = initials ? " <em class=\"chip-ini\">[" + initials + "]</em>" : "";
        sp.innerHTML = e.cat + ": " + e.ml + " mL" + iniLabel + "  <span class=\"del-btn\">[x]</span>";
        sp.querySelector(".del-btn").addEventListener("click", function() {
            removeEntry(sp.dataset.time, parseInt(sp.dataset.idx, 10));
        });
        return sp.outerHTML;
    }

    function removeEntry(time, idx) {
        if (entries[time]) entries[time].splice(idx, 1);
        render();
    }

    function calc() {
        var ti = 0, to = 0;
        Object.keys(entries).forEach(function(k) {
            entries[k].forEach(function(e) { if (e.type === "Intake") ti += e.ml; else to += e.ml; });
        });
        var bal       = ti - to;
        var prevAuto  = parseInt((document.getElementById("prevAuto")  || {value:"0"}).value, 10) || 0;
        var prevManEl = document.getElementById("prevManual");
        var prev      = (prevManEl && prevManEl.value !== "") ? parseInt(prevManEl.value, 10) : prevAuto;
        document.getElementById("inT").innerText  = ti;
        document.getElementById("outT").innerText = to;
        document.getElementById("bal").innerText  = bal;
        document.getElementById("tbal").innerText = bal + prev;
    }

    document.getElementById("btnSaveChart").addEventListener("click", function() {
        var chartDate = document.getElementById("chartDate").value;
        if (!chartDate) { alert("Please enter a chart date."); return; }
        var allEntries = [];
        Object.keys(entries).forEach(function(time) {
            entries[time].forEach(function(e) {
                allEntries.push({ FluidBalanceChartId: 0, EntryDate: e.date, EntryTime: time, EntryType: e.type, Category: e.cat, AmountMl: e.ml, Initials: e.initials || null });
            });
        });
        var ti   = parseInt(document.getElementById("inT").innerText,  10) || 0;
        var to   = parseInt(document.getElementById("outT").innerText, 10) || 0;
        var prevAuto   = parseInt(document.getElementById("prevAuto").value,   10) || 0;
        var prevManual = document.getElementById("prevManual").value;
        var prev       = prevManual !== '' ? parseInt(prevManual, 10) : prevAuto;
        var sigData = null;
        try {
            var blank = document.createElement("canvas");
            blank.width = sigCanvas.width; blank.height = sigCanvas.height;
            if (sigCanvas.toDataURL() !== blank.toDataURL()) sigData = sigCanvas.toDataURL("image/png");
        } catch(err) {}
        var payload = {
            LabId:              parseInt(document.getElementById("txtLabId")     ? document.getElementById("txtLabId").value     : 0) || null,
            PatientId:          parseInt(document.getElementById("txtPatientId") ? document.getElementById("txtPatientId").value : 0) || null,
            ChartDate:          chartDate,
            ChartTime:          document.getElementById("chartTime").value || null,
            PreviousDayBalance: prev,
            TotalIntake:        ti,
            TotalOutput:        to,
            Balance:            ti - to,
            TotalBalance:       (ti - to) + prev,
            ClinicalNotes:      document.getElementById("clinicalNotes").value || null,
            UserInitials:       document.getElementById("userInitials") ? document.getElementById("userInitials").value.trim() || null : null,
            SignatureData:      sigData,
            Entries:            allEntries
        };
        var btn = document.getElementById("btnSaveChart");
        var msg = document.getElementById("saveMsg");
        btn.disabled = true;
        msg.textContent = "Saving...";
        msg.style.color = "#555";
        $.ajax({
            type: "POST",
            url: "/patient/addfluidbalancechart",
            contentType: "application/json",
            data: JSON.stringify(payload),
            success: function(id) {
                btn.disabled = false;
                if (id > 0) {
                    msg.textContent = "Saved Successfully";
                    msg.style.color = "green";
                    var m2 = document.getElementById("saveMsg2"); if(m2){m2.textContent="Saved Successfully";m2.style.color="green";}
                    entries = {};
                    render();
                    document.getElementById("clinicalNotes").value = "";
                    document.getElementById("prevManual").value = "";
                    sigCtx.clearRect(0, 0, sigCanvas.width, sigCanvas.height);
                } else {
                    msg.textContent = "Save failed.";
                    msg.style.color = "red";
                }
            },
            error: function(xhr) {
                btn.disabled = false;
                msg.textContent = "Error " + xhr.status + ": " + xhr.responseText;
                msg.style.color = "red";
                var m2 = document.getElementById("saveMsg2"); if(m2){m2.textContent=msg.textContent;m2.style.color="red";}
            }
        });
    });


    // Default dates and times to now on load
    (function() {
        var now   = new Date();
        var yyyy  = now.getFullYear();
        var mm    = String(now.getMonth()+1).padStart(2,"0");
        var dd    = String(now.getDate()).padStart(2,"0");
        var hh    = String(now.getHours()).padStart(2,"0");
        var mi    = String(now.getMinutes()).padStart(2,"0");
        var today = yyyy+"-"+mm+"-"+dd;
        document.getElementById("chartDate").value = today;
        document.getElementById("chartTime").value = hh+":"+mi;
        document.getElementById("entryDate").value = today;
        // Prevent future dates
        document.getElementById("chartDate").max = today;
        document.getElementById("entryDate").max = today;
    })();

    function printTableSection() { window.print(); }

    // Signature Pad
    var sigCanvas = document.getElementById("signaturePad");
    var sigCtx    = sigCanvas.getContext("2d");
    var sigDrawing = false;

    function resizeSig() {
        var rect = sigCanvas.getBoundingClientRect();
        var ratio = Math.max(window.devicePixelRatio || 1, 1);
        // Only resize if the element has real dimensions
        if (rect.width === 0) { requestAnimationFrame(resizeSig); return; }
        sigCanvas.width  = rect.width  * ratio;
        sigCanvas.height = rect.height * ratio;
        sigCtx.setTransform(1, 0, 0, 1, 0, 0);
        sigCtx.scale(ratio, ratio);
        sigCtx.lineWidth = 2;
        sigCtx.lineCap   = "round";
        sigCtx.strokeStyle = "#111";
    }

    function getPos(e) {
        var rect = sigCanvas.getBoundingClientRect();
        if (e.touches && e.touches.length > 0) {
            return { x: e.touches[0].clientX - rect.left, y: e.touches[0].clientY - rect.top };
        }
        return { x: e.clientX - rect.left, y: e.clientY - rect.top };
    }

    function sigStart(e) { sigDrawing = true; var p = getPos(e); sigCtx.beginPath(); sigCtx.moveTo(p.x, p.y); e.preventDefault(); }
    function sigDraw(e)  { if (!sigDrawing) return; var p = getPos(e); sigCtx.lineTo(p.x, p.y); sigCtx.stroke(); e.preventDefault(); }
    function sigStop(e)  { if (!sigDrawing) return; sigDrawing = false; sigCtx.closePath(); e.preventDefault(); }
    function clearSignature() { sigCtx.clearRect(0, 0, sigCanvas.width, sigCanvas.height); }

    // Use requestAnimationFrame so we measure after the partial view is painted
    requestAnimationFrame(resizeSig);
    window.addEventListener("resize", resizeSig);
    sigCanvas.addEventListener("mousedown",  sigStart);
    sigCanvas.addEventListener("mousemove",  sigDraw);
    sigCanvas.addEventListener("mouseup",    sigStop);
    sigCanvas.addEventListener("mouseleave", sigStop);
    sigCanvas.addEventListener("touchstart", sigStart, { passive: false });
    sigCanvas.addEventListener("touchmove",  sigDraw,  { passive: false });
    sigCanvas.addEventListener("touchend",   sigStop,  { passive: false });

    // On load: fetch prevAuto from DB then run calc so Total Balance shows correctly
    (function fetchPrevAutoOnLoad() {
        var labId     = document.getElementById("txtLabId")     ? document.getElementById("txtLabId").value     : "";
        var patientId = document.getElementById("txtPatientId") ? document.getElementById("txtPatientId").value : "";
        var chartDate = document.getElementById("chartDate").value;
        if (!labId || !patientId || !chartDate) { calc(); return; }
        $.ajax({
            url: "/patient/getlatestfluidbalancetotalbalance",
            method: "GET",
            data: { labId: labId, patientId: patientId, beforeDate: document.getElementById("entryDate").value || chartDate },
            success: function(val) {
                document.getElementById("prevAuto").value = parseInt(val, 10) || 0;
                calc();
            },
            error: function() { calc(); }
        });
    })();

    // Also sync entryDate to chartDate on chartDate change
    document.getElementById("chartDate").addEventListener("change", function() {
        if (!document.getElementById("entryDate").dataset.manuallyChanged) {
            document.getElementById("entryDate").value = this.value;
        }
    });
</script>