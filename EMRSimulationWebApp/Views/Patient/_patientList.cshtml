@{
    ViewData["Title"] = "Patient List";
}
@using EMRSimulation.Domain.Dtos;
@model IEnumerable<PatientDto>

<style>
    .edit-patient-btn { margin-left:8px; }
    .edit-patient-modal { position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:9999; display:none; justify-content:center; align-items:center; }
    .edit-patient-box { width:720px; max-width:92%; background:#fff; padding:22px 26px; border-radius:14px; box-shadow:0 16px 40px rgba(0,0,0,0.30); border:2px solid #ddd; }
    .edit-patient-box h2 { text-align:center; margin:0 0 8px; font-weight:800; font-size:26px; }
    .edit-patient-note { text-align:center; color:#555; margin-bottom:16px; font-size:14px; }
    .edit-patient-info-box { display:flex; align-items:center; gap:14px; background:#f3f6fa; border:1px solid #d6dde6; border-radius:10px; padding:12px 14px; margin-bottom:18px; }
    .edit-avatar { width:46px; height:46px; border-radius:50%; background:#1f6feb; color:#fff; display:flex; align-items:center; justify-content:center; font-size:21px; font-weight:800; flex-shrink:0; }
    .edit-patient-info-text { line-height:1.7; font-size:14px; color:#1f2937; }
    .edit-divider { margin:0 10px; color:#9ca3af; font-weight:bold; }
    .edit-grid { display:grid; grid-template-columns:1fr 1fr; gap:22px; }
    .edit-grid label { display:block; font-weight:700; margin-top:8px; margin-bottom:4px; font-size:14px; }
    .edit-grid input, .edit-grid textarea { width:100%; padding:8px 10px; border:1px solid #bbb; border-radius:6px; font-size:14px; box-sizing:border-box; }
    .edit-grid textarea { height:68px; resize:vertical; }
    .edit-actions { margin-top:22px; display:flex; justify-content:flex-end; gap:12px; }
    .edit-actions button { padding:9px 18px; border-radius:6px; border:none; font-weight:600; cursor:pointer; }
    #closeEditPatient { background:#e5e7eb; color:#111; }
    #saveEditPatient { background:#FF8A30; color:#fff; }
</style>

<div class="text-left">
    <table id="patientsTable" class="display">
        <thead>
            <tr>
                <th>Patient ID</th>
                <th>URI Number</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Date of Birth</th>
                <th>Gender</th>
                <th>Admit Date</th>
                <th>Alerts</th>
                <th></th>
                <th></th>
                <th></th>
                <th></th>
                <th></th>
                <th></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var patient in Model)
            {
                <tr>
                    <td>@patient.Id</td>
                    <td>@patient.UriNumber</td>
                    <td>@patient.FirstName</td>
                    <td>@patient.LastName</td>
                    <td>@patient.DateOfBirth?.ToString("yyyy-MM-dd")</td>
                    <td>@patient.Gender</td>
                    <td>@patient.AdmitDate?.ToString("yyyy-MM-dd")</td>

                    @if (patient.Alert == 1)
                    {
                        <td><img src="~/images/flag.png" height="35px" /></td>
                    }
                    else
                    {
                        <td></td>
                    }

                    <td>@patient.Weight</td>
                    <td>@patient.Height</td>
                    <td>@patient.Age</td>
                    <td>@patient.Allergy</td>
                    <td>@patient.Intolerance</td>
                    <td>@patient.Address</td>

                    <td>
                        <a href="javascript:void(0);" class="btn btn-primary" style="background-color:#FF8A30;">Select</a>
                        <a href="javascript:void(0);" class="btn btn-primary edit-patient-btn" style="background-color:#FF8A30;" data-patientid="@patient.Id">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="patient-card" id="patientCard" style="display:none">
    <div class="patient-header">
        <span id="patientName"></span>
    </div>
    <div class="patient-info">
        <div class="row">
            <div class="col"><strong>URI:</strong> <span id="uri">Kg</span></div>
            <div class="col"><strong>Date of Birth:</strong> <span id="dob">Kg</span></div>
            <div class="col"><strong>Weight:</strong> <span id="weight">Kg</span></div>
            <div class="col"><strong>Height:</strong> <span id="height">Kg</span></div>
            <div class="col"><strong>Age:</strong> <span id="age">Kg</span></div>
            <div class="col"><strong>Gender:</strong> <span id="gender">Kg</span></div>
        </div>
        <div class="row">
            <div class="col">
                <strong class="allergy">Allergy:</strong>
                <div id="allergy" class="allergy"></div>
            </div>
            <div class="col">
                <strong>Intolerance:</strong>
                <div id="intolerance"></div>
            </div>
            <div class="col">
                <strong>Address:</strong>
                <div id="address"></div>
            </div>
        </div>
    </div>
</div>

<button id="btnViewPatientRecords" class="btn btn-primary" style="background-color:#FF8A30;float: right; display:none">View Patient Records</button>

<div id="editPatientModal" class="edit-patient-modal">
    <div class="edit-patient-box">
        <h2>Edit Patient Details</h2>
        <p class="edit-patient-note">Update only the fields that need changes. If a field is left blank, the existing value will remain unchanged.</p>
        <input type="hidden" id="editPatientId" />
        <div class="edit-patient-info-box">
            <div class="edit-avatar">P</div>
            <div class="edit-patient-info-text">
                <strong>URI NUMBER - </strong><span id="editInfoUri"></span>
                <span class="edit-divider">|</span>
                <strong>PATIENT NAME - </strong><span id="editInfoName"></span>
                <br />
                <strong>DATE OF BIRTH - </strong><span id="editInfoDob"></span>
                <span class="edit-divider">|</span>
                <strong>GENDER - </strong><span id="editInfoGender"></span>
            </div>
        </div>
        <div class="edit-grid">
            <div>
                <label>First Name</label><input type="text" id="editFirstName">
                <label>Last Name</label><input type="text" id="editLastName">
                <label>Date of Birth</label><input type="date" id="editDob">
                <label>Gender</label><input type="text" id="editGender">
                <label>Address</label><textarea id="editAddress"></textarea>
            </div>
            <div>
                <label>Allergy</label><input type="text" id="editAllergy">
                <label>Intolerance</label><input type="text" id="editIntolerance">
                <label>Weight</label><input type="text" id="editWeight">
                <label>Height</label><input type="text" id="editHeight">
                <label>Age</label><input type="text" id="editAge">
            </div>
        </div>
        <div class="edit-actions">
            <button type="button" id="closeEditPatient">Cancel</button>
            <button type="button" id="saveEditPatient">Save Changes</button>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        console.log("_patientList.cshtml doc ready");

        var table = $('#patientsTable').DataTable({
            "paging": true,
            "info": false,
            "searching": false,
            "ordering": true,
            "autoWidth": false,
            "lengthChange": false,
            "pageLength": 10
            ,
            "columnDefs": [
                {   "targets": [0,8,9,10,11,12,13],
                    "visible": false
                }
            ]
        });

        // Row click event to get first name and display it
        $('#patientsTable tbody').on('click', 'tr', function (e) {
            if ($(e.target).hasClass("edit-patient-btn")) { return; }

            var data = table.row(this).data();

            var patientId = data[0];
            var uri = data[1];
            var firstName = data[2];
            var lastName = data[3];
            var dateOfBirth = data[4];
            var weight = data[8];
            var height = data[9];
            var age = data[10];
            var gender = data[5];            
            var allergy = data[11];
            var intolerance = data[12];
            var address = data[13];

            var patientInfo = "";
            patientInfo = "<b>First Name:</b> " + firstName + "<BR/>"
            patientInfo += "<b>Last Name: </b>" + lastName + "<BR/>"
            patientInfo += "<b>DOB: </b>" + dateOfBirth + "<BR/>"
            patientInfo += "<b>Gender: </b>" + gender + "<BR/>"

            $('#patientInformation').html(patientInfo);
            $('#divPatientInformation').show();

            // Display the first name in the div
            $('#patientName').text(firstName + " " + lastName);
            $('#uri').text(uri);
            $('#dob').text(dateOfBirth);
            $('#weight').html(weight);
            $('#height').text(height);
            $('#age').text(age);
            $('#gender').text(gender);
            $('#address').text(address);
            $('#txtPatientId').val(patientId);

            if (allergy && allergy.trim() !== '') {
                
                var allergyList = allergy.split(',');

                var allergyHtml = '<ul>';
                allergyList.forEach(function (allergy) {
                    allergyHtml += '<li>' + allergy + '</li>';
                });
                allergyHtml += '</ul>';

                // Display the allergy
                $('#allergy').html(allergyHtml);
            }

            if (intolerance && intolerance.trim() !== '') {

                var intoleranceList = intolerance.split(',');

                var intoleranceHtml = '<ul>';
                intoleranceList.forEach(function (intolerance) {
                    intoleranceHtml += '<li>' + intolerance + '</li>';
                });
                intoleranceHtml += '</ul>';

                // Display the intolerance
                $('#intolerance').html(intoleranceHtml);
            }

            $('#patientCard').show();
            $('#btnViewPatientRecords').show();
        });

        // Toggle Flow Sheet Menu
        $(document).on('click', '#btnViewPatientRecords', function () {
            $("#toggleRecordMenu").show();
            $("#toggleProgressMenu").show()
            $("#togglePatientUsecaseMenu").show();
            
            var LabId = $('#txtLabId').val();
            var PatientId = $('#txtPatientId').val();

            $.ajax({
                url: "/patient/getpatientrecord",
                method: "GET",
                data: { labId: LabId, patientId: PatientId },
                success: function (response) {
                    // Load the response into the right-side content area
                    $('#content-area').html("");
                    $('#patient-header').html("");
                    $('#patient-header').html(response);
                },
                error: function (xhr, status, error) {
                    console.error("Error loading the page:", error);
                }
            });
                
        });

        // ===== Edit Patient feature =====
        $('#patientsTable').on('click', '.edit-patient-btn', function (e) {
            e.preventDefault();
            e.stopPropagation();
            var row = $(this).closest('tr');
            var data = table.row(row).data();
            if (!data) { alert("Could not read patient row."); return; }

            $("#editPatientId").val(data[0]);
            $("#editInfoUri").text(data[1]);
            $("#editInfoName").text(data[2] + " " + data[3]);
            $("#editInfoDob").text(data[4]);
            $("#editInfoGender").text(data[5]);
            if (data[2]) { $(".edit-avatar").text(data[2].charAt(0).toUpperCase()); }

            $("#editFirstName").val(data[2]);
            $("#editLastName").val(data[3]);
            $("#editDob").val(data[4]);
            $("#editGender").val(data[5]);
            $("#editWeight").val(data[8]);
            $("#editHeight").val(data[9]);
            $("#editAge").val(data[10]);
            $("#editAllergy").val(data[11]);
            $("#editIntolerance").val(data[12]);
            $("#editAddress").val(data[13]);

            $("#editPatientModal").css("display", "flex").hide().fadeIn(180);
        });

        $(document).on("click", "#closeEditPatient", function () {
            $("#editPatientModal").fadeOut(180);
        });

        $(document).on("click", "#saveEditPatient", function () {
            var patientId = $("#editPatientId").val();
            var firstName = $("#editFirstName").val();
            var lastName = $("#editLastName").val();
            var dob = $("#editDob").val();
            var gender = $("#editGender").val();
            var address = $("#editAddress").val();
            var allergy = $("#editAllergy").val();
            var intolerance = $("#editIntolerance").val();
            var weight = $("#editWeight").val();
            var height = $("#editHeight").val();
            var age = $("#editAge").val();

            $.ajax({
                url: "/Patient/UpdatePatientFromList",
                type: "POST",
                data: { patientId, firstName, lastName, dob, gender, address, allergies: allergy, intolerance, weight, height, age },
                success: function () {
                    var row = $('.edit-patient-btn[data-patientid="' + patientId + '"]').closest('tr');
                    var rowData = table.row(row).data();
                    if (rowData) {
                        rowData[2] = firstName; rowData[3] = lastName; rowData[4] = dob; rowData[5] = gender;
                        rowData[8] = weight; rowData[9] = height; rowData[10] = age;
                        rowData[11] = allergy; rowData[12] = intolerance; rowData[13] = address;
                        table.row(row).data(rowData).draw(false);
                    }
                    $("#editPatientModal").fadeOut(180);
                },
                error: function () { alert("Update failed. Please check PatientController method."); }
            });
        });

    });

</script>
