@using EMRSimulation.Domain.Dtos
@model IEnumerable<FallRiskDto>
@{
    Layout = null;
}

@functions {
    private string FlagText(FallRiskDto r)
    {
        var parts = new List<string>();
        if (r.AutoCondChange) parts.Add("Cond/med change");
        if (r.AutoDizziness) parts.Add("Dizziness/postural hypotension");
        if (r.AutoAnaesthetic) parts.Add("Anaesthetic/major op <24h / PCA");
        return parts.Count == 0 ? "-" : string.Join(", ", parts);
    }
}

<div class="container-fluid">
    <h4 class="mb-3">Fall Risk Assessments – List</h4>

    <div class="table-responsive">
        <table id="fratTable" class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Assessed At</th>
                    <th>Total</th>
                    <th>Risk</th>
                    <th>Recent Falls</th>
                    <th>Medications</th>
                    <th>Psychological</th>
                    <th>Cognitive</th>
                    <th>Auto High-Risk</th>
                    <th>Assessor</th>
                    <!--
                    <th>Notes</th>
                    -->
                    <th>Interventions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var r in Model)
                    {
                        var badgeClass = "bg-secondary";
                        if (string.Equals(r.RiskLevel, "High", StringComparison.OrdinalIgnoreCase)) badgeClass = "bg-danger";
                        else if (string.Equals(r.RiskLevel, "Medium", StringComparison.OrdinalIgnoreCase)) badgeClass = "bg-warning text-dark";
                        else if (string.Equals(r.RiskLevel, "Low", StringComparison.OrdinalIgnoreCase)) badgeClass = "bg-success";

                        var flags = FlagText(r);

                        var safeNotes = (r.Notes ?? string.Empty).Trim();
                        var shortNotes = safeNotes.Length > 40 ? safeNotes.Substring(0, 40) + "…" : safeNotes;

                        var safeInterv = (r.InterventionNotes ?? string.Empty).Trim();
                        var shortInterv = safeInterv.Length > 40 ? safeInterv.Substring(0, 40) + "…" : safeInterv;

                        <tr>
                            <td>@r.AssessedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@r.TotalScore</td>
                            <td><span class="badge @badgeClass">@r.RiskLevel</span></td>
                            <td>@r.RecentFallsScore</td>
                            <td>@r.MedicationsScore</td>
                            <td>@r.PsychologicalScore</td>
                            <td>@r.CognitiveScore</td>
                            <td>
                                @if (flags == "-")
                                {
                                    <span>-</span>
                                }
                                else
                                {

                                    <span class="badge bg-info text-dark" title="@flags">Yes</span>
                                }
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(r.Assessor) ? "-" : r.Assessor)</td>
                            <!--
                            <td title="@safeNotes">@Html.Raw(System.Net.WebUtility.HtmlEncode(shortNotes))</td>
                            -->
                            <td title="@safeInterv">@Html.Raw(System.Net.WebUtility.HtmlEncode(shortInterv))</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <button type="button"
                class="btn btn-outline-primary load-patient-frat-after-list"
                data-url='@Url.Action("GetPatientFallRiskChart", "Patient")'>
            + New Assessment
        </button>
    </div>
</div>
<script>
    (function () {
        if ($ && $.fn && $.fn.DataTable) {
            $('#fratTable').DataTable({
                pageLength: 10,
                order: [[0, 'desc']],
                dom: 'lrtip'
            });
        }

        $('.load-patient-frat-after-list').on('click', function (e) {
            e.preventDefault();
            var pageUrl = $(this).data('url');   // /Patient/GetPatientFallRiskChart
            var LabId = $('#txtLabId').val();
            var PatientId = $('#txtPatientId').val();

            $.ajax({
                url: pageUrl,
                method: "GET",
                data: { labId: LabId, patientId: PatientId },
                success: function (response) {
                    $('#content-area').html("");
                    $('#content-area').html(response);
                    $('#flowSheetMenu a').removeClass('active');
                    $('.load-patient-frat').addClass('active');
                },
                error: function (xhr, status, error) {
                    console.error("Error loading FRAT:", error);
                }
            });
        });
    })();
</script>
