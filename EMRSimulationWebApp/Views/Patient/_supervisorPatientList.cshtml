@{
    ViewData["Title"] = "Patient List";
}
@using EMRSimulation.Domain.Dtos;
@model IEnumerable<PatientDto>

<div class="text-left">
    <table id="patientssTable" class="display">
        <thead>
            <tr>
                <th>Patient ID</th>
                <th>URI Number</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Date of Birth</th>
                <th>Gender</th>
                <th>Admit Date</th>
                <th></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var patient in Model)
            {
                <tr>
                    <td>@patient.Id</td>
                    <td>@patient.UriNumber</td>
                    <td>@patient.FirstName</td>
                    <td>@patient.LastName</td>
                    <td>@patient.DateOfBirth?.ToString("yyyy-MM-dd")</td>
                    <td>@patient.Gender</td>
                    <td>@patient.AdmitDate?.ToString("yyyy-MM-dd")</td>
                    <td>
                        <a href="javascript:void(0);" class="btn btn-primary clearPatientData" data-custom="@patient.Id" style="background-color:#FF8A30;">Clear Records</a>
                    </td>
                    <td>
                        <a href="javascript:void(0);" class="btn btn-primary deletePatientData" data-custom="@patient.Id" style="background-color:#FF8A30;">Delete Patient</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal -->
<div class="modal fade" id="clearPatientModal" tabindex="-1" aria-labelledby="clearPatientModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="clearPatientModalLabel">Confirm Patient Record Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="clearRecordsSelector">
                    <p class="text-muted small mb-2">Select which record types to clear for this patient. Unticked records are left untouched.</p>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Records</strong>
                        <a href="javascript:void(0);" id="toggleAllRecords" class="small">Select all</a>
                    </div>
                    <div class="list-group">
                        <label class="list-group-item d-flex align-items-center gap-2"><input type="checkbox" class="form-check-input m-0 recordChk" data-flag="fallRisk"> Student Fall Risk Assessments</label>
                        <label class="list-group-item d-flex align-items-center gap-2"><input type="checkbox" class="form-check-input m-0 recordChk" data-flag="braden"> Student Braden Assessment</label>
                        <label class="list-group-item d-flex align-items-center gap-2"><input type="checkbox" class="form-check-input m-0 recordChk" data-flag="neuro"> Student Neurological Administration</label>
                        <label class="list-group-item d-flex align-items-center gap-2"><input type="checkbox" class="form-check-input m-0 recordChk" data-flag="foodIntake"> Student Food Intake</label>
                        <label class="list-group-item d-flex align-items-center gap-2"><input type="checkbox" class="form-check-input m-0 recordChk" data-flag="ivFluid"> Student Iv Fluid</label>
                        <label class="list-group-item d-flex align-items-center gap-2"><input type="checkbox" class="form-check-input m-0 recordChk" data-flag="prn"> Student PRN Medication</label>
                        <label class="list-group-item d-flex align-items-center gap-2"><input type="checkbox" class="form-check-input m-0 recordChk" data-flag="regular"> Student Regular Medication</label>
                        <label class="list-group-item d-flex align-items-center gap-2"><input type="checkbox" class="form-check-input m-0 recordChk" data-flag="patientAdds"> Student Patient Adds</label>
                        <label class="list-group-item d-flex align-items-center gap-2"><input type="checkbox" class="form-check-input m-0 recordChk" data-flag="progressNotes"> Student Progress Notes</label>
                    </div>
                </div>
                <div id="clearRecordsResult" class="text-center" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="clearSelectedBtn">Clear Selected</button>
                <button type="button" class="btn btn-secondary" style="background-color:black; display:none;" id="clearDoneBtn" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Confirm Delete Patient Modal -->
<div class="modal fade" id="deletePatientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <p class="fw-bold mb-2">Are you sure you want to delete this patient?</p>
                <p class="text-danger mb-0">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger" id="confirmDeletePatientBtn">Yes, Delete</button>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var selectedDeletePatientId = null;

        var table = $('#patientssTable').DataTable({
            "paging": true, 
            "info": false, 
            "searching": false, 
            "ordering": true, 
            "autoWidth": false, 
            "lengthChange": false,  
            "pageLength": 5,
            "columnDefs": [
                {   "targets": [0],
                    "visible": false
                }
            ]
        });

        var clearPatientIdSel = null;

        $('#patientssTable').on('click', '.clearPatientData', function() {
            clearPatientIdSel = $(this).attr("data-custom");
            // Reset modal to its selectable state each time it opens
            $('.recordChk').prop('checked', false);
            $('#toggleAllRecords').text('Select all');
            $('#clearRecordsSelector').show();
            $('#clearRecordsResult').hide().html('');
            $('#clearSelectedBtn').show();
            $('#clearDoneBtn').hide();
            $('#clearPatientModalLabel').text('Confirm Patient Record Deletion');
            $('#clearPatientModal').modal('show');
        });

        $('#toggleAllRecords').on('click', function() {
            var allChecked = $('.recordChk:checked').length === $('.recordChk').length;
            $('.recordChk').prop('checked', !allChecked);
            $(this).text(allChecked ? 'Select all' : 'Deselect all');
        });

        $('#clearSelectedBtn').on('click', function() {
            var LabId = $('#txtLabId').val();
            var flags = { labId: LabId, patientId: clearPatientIdSel,
                fallRisk:false, braden:false, neuro:false, foodIntake:false, ivFluid:false,
                prn:false, regular:false, patientAdds:false, progressNotes:false };
            var anySelected = false;
            $('.recordChk:checked').each(function() {
                flags[$(this).data('flag')] = true;
                anySelected = true;
            });
            if (!anySelected) { alert("Please select at least one record type to clear."); return; }

            $.ajax({
                type: "GET",
                url: "/supervisor/clearpatientdataselective",
                data: flags,
                success: function (response) {
                    let tableHtml = '<table class="table table-striped"><thead><tr><th style="text-align:left">Record</th><th>Rows Deleted</th></tr></thead><tbody>';
                    response.forEach(item => {
                        tableHtml += `<tr><td style='text-align:left'>${item.moduleName}</td><td>${item.rowsDeleted}</td></tr>`;
                    });
                    tableHtml += '</tbody></table>';
                    $('#clearRecordsSelector').hide();
                    $('#clearRecordsResult').html(tableHtml).show();
                    $('#clearPatientModalLabel').text('Cleared Patient Records');
                    $('#clearSelectedBtn').hide();
                    $('#clearDoneBtn').show();
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    console.log("Error:", textStatus);
                    alert("An error occurred while clearing records.");
                }
            });
        });

        // Show confirmation modal instead of deleting immediately
        $('#patientssTable').on('click', '.deletePatientData', function() {
            selectedDeletePatientId = $(this).attr("data-custom");
            $('#deletePatientModal').modal('show');
        });

        // Actual delete runs only after the user confirms
        $('#confirmDeletePatientBtn').on('click', function() {

            var LabId = $('#txtLabId').val();
            var patientId = selectedDeletePatientId;

            $.ajax({
                type: "GET",
                url: "/supervisor/deletepatient",
                contentType: "application/json",
                data: { labId: LabId, Id: patientId },
                success: function (response) {
                if (response > 0) {

                    $('#deletePatientModal').modal('hide');

                    $.ajax({
                        url: "/supervisor/getsupervisorpatientlist",
                        method: "GET",
                        data: { labId: LabId },
                        success: function (response) {
                            // Load the response into the right-side content area
                            $('#content-area').html("");
                            $('#content-area').html(response);
                        },
                        error: function (xhr, status, error) {
                            console.error("Error loading the page:", error);
                        }
                    });

                } else {
                    $('#lblMessage').text("Error").css('color', 'red');
                }

                console.log("Success:", response);
            },
            error: function (jqXHR, textStatus, errorThrown) {
                console.log("Error:", textStatus);
            }
                
            });
        });

    });

</script>