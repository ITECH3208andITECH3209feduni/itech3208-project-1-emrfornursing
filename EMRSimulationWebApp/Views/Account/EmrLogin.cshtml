@{
    ViewData["Title"] = "FedUni - Emr Simulation";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="hero-section">
    <div class="hero-left">
        <h1>Electronic<br>Medical<br>Records (EMR)<br>Simulator</h1>
        <div class="subtitle">Digital Medical Record Training</div>
    </div>
    <div class="hero-right">
        <div class="monitor-container">
            <img src="/images/monitor.png" alt="EMR System Monitor" class="monitor-image">
        </div>
    </div>
</div>

<div class="footer-section">
    <div class="footer-content">
        <div class="university-logo">
            <div class="logo-icon"></div>
        </div>
        <div class="login-buttons">
            <button class="btn btn-login btn-student">
                Log In<br>Student
            </button>
            <button class="btn btn-login btn-supervisor">
                Log In<br>Supervisor
            </button>
        </div>
    </div>
</div>
