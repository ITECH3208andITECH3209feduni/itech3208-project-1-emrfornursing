using System;
using System.Collections.Generic;

namespace EMRSimulation.Domain.Dtos
{
    /// <summary>
    /// Maps to the new [dbo].[FluidBalanceChart] table.
    /// One record = one 24-hour chart day for a patient.
    /// </summary>
    public class FluidBalanceChartDto
    {
        public int Id { get; set; }
        public int? LabId { get; set; }
        public int? PatientId { get; set; }

        /// <summary>ChartDate (SQL date, non-nullable in DB)</summary>
        public DateTime ChartDate { get; set; }

        /// <summary>ChartTime stored as HH:mm string (e.g. "14:30") — maps to SQL time(7)</summary>
        public string? ChartTime { get; set; }

        public int PreviousDayBalance { get; set; }
        public int TotalIntake { get; set; }
        public int TotalOutput { get; set; }

        /// <summary>Balance = TotalIntake - TotalOutput</summary>
        public int Balance { get; set; }

        /// <summary>TotalBalance = Balance + PreviousDayBalance</summary>
        public int TotalBalance { get; set; }

        public string? ClinicalNotes { get; set; }
        public string? UserInitials { get; set; }

        /// <summary>Base-64 PNG string from the signature canvas</summary>
        public string? SignatureData { get; set; }

        public DateTime CreatedDateTime { get; set; }
        public DateTime? UpdatedDateTime { get; set; }

        /// <summary>Child entries — populated when reading a single chart by Id.</summary>
        public List<FluidBalanceChartEntryDto> Entries { get; set; } = new();
    }

    /// <summary>
    /// Maps to the new [dbo].[FluidBalanceChartEntry] table.
    /// One record = one individual time-stamped fluid entry (intake or output).
    /// </summary>
    public class FluidBalanceChartEntryDto
    {
        public int Id { get; set; }
        public int FluidBalanceChartId { get; set; }

        /// <summary>4-char 24-h time string, e.g. "0800" or "1400"</summary>
        public string EntryTime { get; set; } = string.Empty;

        /// <summary>"Intake" or "Output"</summary>
        public string EntryType { get; set; } = string.Empty;

        /// <summary>e.g. "IV Fluids", "Oral Intake", "Urine Output", "Drainage" …</summary>
        public string Category { get; set; } = string.Empty;

        public int AmountMl { get; set; }

        public DateTime CreatedDateTime { get; set; }
    }
}
