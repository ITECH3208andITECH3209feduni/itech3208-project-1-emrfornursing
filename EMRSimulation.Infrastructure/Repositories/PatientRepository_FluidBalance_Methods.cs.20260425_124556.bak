using EMRSimulation.Domain.Dtos;
using System.Data;
using System.Data.SqlClient;

namespace EMRSimulation.Infrastructure.Repositories
{
    public partial class PatientRepository
    {
        #region Fluid Balance Chart

        public async Task<int> AddFluidBalanceChartAsync(FluidBalanceChartDto dto)
        {
            using var connection = await _dbConnectionFactory.CreateAsync();
            using var command = (SqlCommand)connection.CreateCommand();
            command.CommandType = CommandType.StoredProcedure;
            command.CommandText = "InsertFluidBalanceChart";

            command.Parameters.Add(new SqlParameter("@LabId", (object?)dto.LabId ?? DBNull.Value));
            command.Parameters.Add(new SqlParameter("@PatientId", (object?)dto.PatientId ?? DBNull.Value));
            command.Parameters.Add(new SqlParameter("@ChartDate", dto.ChartDate));
            command.Parameters.Add(new SqlParameter("@ChartTime", (object?)dto.ChartTime ?? DBNull.Value));
            command.Parameters.Add(new SqlParameter("@PreviousDayBalance", dto.PreviousDayBalance));
            command.Parameters.Add(new SqlParameter("@TotalIntake", dto.TotalIntake));
            command.Parameters.Add(new SqlParameter("@TotalOutput", dto.TotalOutput));
            command.Parameters.Add(new SqlParameter("@Balance", dto.Balance));
            command.Parameters.Add(new SqlParameter("@TotalBalance", dto.TotalBalance));
            command.Parameters.Add(new SqlParameter("@ClinicalNotes", (object?)dto.ClinicalNotes ?? DBNull.Value));
            command.Parameters.Add(new SqlParameter("@UserInitials", (object?)dto.UserInitials ?? DBNull.Value));
            command.Parameters.Add(new SqlParameter("@SignatureData", (object?)dto.SignatureData ?? DBNull.Value));

            var scalar = await command.ExecuteScalarAsync();
            return (scalar == null || scalar == DBNull.Value) ? 0 : Convert.ToInt32(scalar);
        }

        public async Task<IEnumerable<FluidBalanceChartDto>> GetFluidBalanceChartsAsync(int labId, int patientId)
        {
            var list = new List<FluidBalanceChartDto>();

            using var connection = await _dbConnectionFactory.CreateAsync();
            using var command = (SqlCommand)connection.CreateCommand();
            command.CommandType = CommandType.StoredProcedure;
            command.CommandText = "GetFluidBalanceCharts";
            command.Parameters.Add(new SqlParameter("@LabId", labId));
            command.Parameters.Add(new SqlParameter("@PatientId", patientId));

            using var reader = await command.ExecuteReaderAsync();
            while (await reader.ReadAsync())
                list.Add(MapFluidBalanceChart(reader));

            return list;
        }

        public async Task<FluidBalanceChartDto?> GetFluidBalanceChartByIdAsync(int id, int labId)
        {
            using var connection = await _dbConnectionFactory.CreateAsync();
            using var command = (SqlCommand)connection.CreateCommand();
            command.CommandType = CommandType.StoredProcedure;
            command.CommandText = "GetFluidBalanceChartById";
            command.Parameters.Add(new SqlParameter("@Id", id));
            command.Parameters.Add(new SqlParameter("@LabId", labId));

            using var reader = await command.ExecuteReaderAsync();

            FluidBalanceChartDto? dto = null;
            if (await reader.ReadAsync())
                dto = MapFluidBalanceChart(reader);

            if (dto == null) return null;

            if (await reader.NextResultAsync())
            {
                while (await reader.ReadAsync())
                    dto.Entries.Add(MapFluidBalanceEntry(reader));
            }

            return dto;
        }

        public async Task<(int id, string resultMessage)> DeleteFluidBalanceChartAsync(int id)
        {
            using var connection = await _dbConnectionFactory.CreateAsync();
            using var command = (SqlCommand)connection.CreateCommand();
            command.CommandType = CommandType.StoredProcedure;
            command.CommandText = "DeleteFluidBalanceChart";
            command.Parameters.Add(new SqlParameter("@Id", id));

            using var reader = await command.ExecuteReaderAsync();
            if (await reader.ReadAsync())
                return (reader.GetInt32(reader.GetOrdinal("RowsAffected")),
                        reader.GetString(reader.GetOrdinal("ResultMessage")));

            return (0, "Not found");
        }

        #endregion

        #region Fluid Balance Chart Entries

        public async Task<int> AddFluidBalanceChartEntryAsync(FluidBalanceChartEntryDto dto)
        {
            using var connection = await _dbConnectionFactory.CreateAsync();
            using var command = (SqlCommand)connection.CreateCommand();
            command.CommandType = CommandType.StoredProcedure;
            command.CommandText = "InsertFluidBalanceChartEntry";

            command.Parameters.Add(new SqlParameter("@FluidBalanceChartId", dto.FluidBalanceChartId));
            command.Parameters.Add(new SqlParameter("@EntryTime", dto.EntryTime));
            command.Parameters.Add(new SqlParameter("@EntryType", dto.EntryType));
            command.Parameters.Add(new SqlParameter("@Category", dto.Category));
            command.Parameters.Add(new SqlParameter("@AmountMl", dto.AmountMl));

            var scalar = await command.ExecuteScalarAsync();
            return (scalar == null || scalar == DBNull.Value) ? 0 : Convert.ToInt32(scalar);
        }

        public async Task<IEnumerable<FluidBalanceChartEntryDto>> GetFluidBalanceChartEntriesAsync(int fluidBalanceChartId)
        {
            var list = new List<FluidBalanceChartEntryDto>();

            using var connection = await _dbConnectionFactory.CreateAsync();
            using var command = (SqlCommand)connection.CreateCommand();
            command.CommandType = CommandType.StoredProcedure;
            command.CommandText = "GetFluidBalanceChartEntries";
            command.Parameters.Add(new SqlParameter("@FluidBalanceChartId", fluidBalanceChartId));

            using var reader = await command.ExecuteReaderAsync();
            while (await reader.ReadAsync())
                list.Add(MapFluidBalanceEntry(reader));

            return list;
        }

        public async Task<int> DeleteFluidBalanceChartEntryAsync(int id)
        {
            using var connection = await _dbConnectionFactory.CreateAsync();
            using var command = (SqlCommand)connection.CreateCommand();
            command.CommandType = CommandType.StoredProcedure;
            command.CommandText = "DeleteFluidBalanceChartEntry";
            command.Parameters.Add(new SqlParameter("@Id", id));

            var scalar = await command.ExecuteScalarAsync();
            return (scalar == null || scalar == DBNull.Value) ? 0 : Convert.ToInt32(scalar);
        }

        #endregion

        #region Private mappers

        private static FluidBalanceChartDto MapFluidBalanceChart(SqlDataReader r)
        {
            return new FluidBalanceChartDto
            {
                Id = r.GetInt32(r.GetOrdinal("Id")),
                LabId = r.IsDBNull(r.GetOrdinal("LabId")) ? null : r.GetInt32(r.GetOrdinal("LabId")),
                PatientId = r.IsDBNull(r.GetOrdinal("PatientId")) ? null : r.GetInt32(r.GetOrdinal("PatientId")),
                ChartDate = r.GetDateTime(r.GetOrdinal("ChartDate")),
                ChartTime = r.IsDBNull(r.GetOrdinal("ChartTime")) ? null : r.GetTimeSpan(r.GetOrdinal("ChartTime")),
                PreviousDayBalance = r.IsDBNull(r.GetOrdinal("PreviousDayBalance")) ? 0 : r.GetInt32(r.GetOrdinal("PreviousDayBalance")),
                TotalIntake = r.GetInt32(r.GetOrdinal("TotalIntake")),
                TotalOutput = r.GetInt32(r.GetOrdinal("TotalOutput")),
                Balance = r.GetInt32(r.GetOrdinal("Balance")),
                TotalBalance = r.GetInt32(r.GetOrdinal("TotalBalance")),
                ClinicalNotes = r.IsDBNull(r.GetOrdinal("ClinicalNotes")) ? null : r.GetString(r.GetOrdinal("ClinicalNotes")),
                UserInitials = r.IsDBNull(r.GetOrdinal("UserInitials")) ? null : r.GetString(r.GetOrdinal("UserInitials")),
                SignatureData = r.IsDBNull(r.GetOrdinal("SignatureData")) ? null : r.GetString(r.GetOrdinal("SignatureData")),
                CreatedDateTime = r.GetDateTime(r.GetOrdinal("CreatedDateTime")),
                UpdatedDateTime = r.IsDBNull(r.GetOrdinal("UpdatedDateTime")) ? null : r.GetDateTime(r.GetOrdinal("UpdatedDateTime")),
            };
        }

        private static FluidBalanceChartEntryDto MapFluidBalanceEntry(SqlDataReader r)
        {
            return new FluidBalanceChartEntryDto
            {
                Id = r.GetInt32(r.GetOrdinal("Id")),
                FluidBalanceChartId = r.GetInt32(r.GetOrdinal("FluidBalanceChartId")),
                EntryTime = r.GetString(r.GetOrdinal("EntryTime")),
                EntryType = r.GetString(r.GetOrdinal("EntryType")),
                Category = r.GetString(r.GetOrdinal("Category")),
                AmountMl = r.GetInt32(r.GetOrdinal("AmountMl")),
                CreatedDateTime = r.GetDateTime(r.GetOrdinal("CreatedDateTime")),
            };
        }

        #endregion
    }
}
